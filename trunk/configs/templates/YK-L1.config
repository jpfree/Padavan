# Padavan YK-L1 device configuration

CONFIG_VENDOR=Ralink
CONFIG_PRODUCT=YK-L1
CONFIG_FIRMWARE_PRODUCT_ID="YK-L1"

# CPU / SoC
CONFIG_RALINK_MT7628=y
CONFIG_FIRMWARE_CPU_MT7628=y

# Flash layout
CONFIG_FIRMWARE_FLASH_SIZE_16M=y
# CONFIG_FIRMWARE_FLASH_SIZE_8M is not set
# CONFIG_FIRMWARE_FLASH_SIZE_4M is not set

# Kernel
CONFIG_LINUXDIR=linux-3.4.x

# Filesystem
CONFIG_FIRMWARE_INCLUDE_SQUASHFS=y
CONFIG_FIRMWARE_INCLUDE_JFFS2=n

# Wireless
CONFIG_FIRMWARE_INCLUDE_WIFI_DRIVER=y
CONFIG_FIRMWARE_WIFI_DRIVER_RALINK=y
CONFIG_FIRMWARE_WIFI_RT_SECOND_IF=n
CONFIG_FIRMWARE_INCLUDE_5G=n

# Ethernet
CONFIG_FIRMWARE_INCLUDE_ETH=y

# USB
CONFIG_FIRMWARE_INCLUDE_USB=n
CONFIG_FIRMWARE_INCLUDE_USB_3G=n
CONFIG_FIRMWARE_INCLUDE_USB_PRINTER=n
CONFIG_FIRMWARE_INCLUDE_USB_STORAGE=n
CONFIG_FIRMWARE_INCLUDE_FAT=n
CONFIG_FIRMWARE_INCLUDE_NTFS=n
CONFIG_FIRMWARE_INCLUDE_EXFAT=n

# IPv6
CONFIG_FIRMWARE_INCLUDE_IPV6=n

# NAT
CONFIG_FIRMWARE_INCLUDE_NAT_CONE=y
CONFIG_FIRMWARE_INCLUDE_NAT_LINUX=n

# Fastpath / Flow Acceleration
CONFIG_FIRMWARE_INCLUDE_FASTPATH=y
CONFIG_FIRMWARE_INCLUDE_SHORTCUT_FE=y
CONFIG_FIRMWARE_INCLUDE_HW_NAT=y

# Netfilter / Conntrack
CONFIG_FIRMWARE_INCLUDE_CONNTRACK=y
CONFIG_FIRMWARE_INCLUDE_CONNTRACK_EVENTS=n
CONFIG_FIRMWARE_INCLUDE_CONNTRACK_CHAIN_EVENTS=n

# QoS
CONFIG_FIRMWARE_INCLUDE_QOS=y
CONFIG_FIRMWARE_INCLUDE_IFB=y

# VPN
CONFIG_FIRMWARE_INCLUDE_OPENVPN=n
CONFIG_FIRMWARE_INCLUDE_WIREGUARD=n
CONFIG_FIRMWARE_INCLUDE_IPSEC=n

# DNS / DHCP
CONFIG_FIRMWARE_INCLUDE_DNSFORWARDER=y
CONFIG_FIRMWARE_INCLUDE_DNSMASQ=y

# Web UI
CONFIG_FIRMWARE_INCLUDE_WEBUI=y
CONFIG_FIRMWARE_INCLUDE_HTTPS=n

# Dropbear SSH
CONFIG_FIRMWARE_INCLUDE_DROPBEAR=y
CONFIG_FIRMWARE_INCLUDE_DROPBEAR_FAST_CODE=y

# Busybox
CONFIG_FIRMWARE_INCLUDE_BUSYBOX=y

# Tools
CONFIG_FIRMWARE_INCLUDE_TTYD=n
CONFIG_FIRMWARE_INCLUDE_HTOP=n
CONFIG_FIRMWARE_INCLUDE_NANO=n
CONFIG_FIRMWARE_INCLUDE_VIM=n
CONFIG_FIRMWARE_INCLUDE_CURL=n
CONFIG_FIRMWARE_INCLUDE_WGET=y

# Storage services
CONFIG_FIRMWARE_INCLUDE_FTPD=n
CONFIG_FIRMWARE_INCLUDE_SAMBA=n
CONFIG_FIRMWARE_INCLUDE_MINIDLNA=n

# Misc
CONFIG_FIRMWARE_INCLUDE_HTTPS_DDNS=n
CONFIG_FIRMWARE_INCLUDE_ALIDDNS=n
CONFIG_FIRMWARE_INCLUDE_CLOUDCHECK=n
CONFIG_FIRMWARE_INCLUDE_SMARTDNS=n
CONFIG_FIRMWARE_INCLUDE_ADGUARDHOME=n

# LED / Buttons
CONFIG_FIRMWARE_INCLUDE_GPIO=y

# Debug
CONFIG_FIRMWARE_INCLUDE_TELNET=y
CONFIG_FIRMWARE_INCLUDE_LOGREAD=y
